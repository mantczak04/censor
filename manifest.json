{
  "manifest_version": 3,
  "name": "Messenger Style Redactor",
  "version": "1.0.0",
  "description": "Rewrite Messenger messages via local Ollama before sending.",

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:11434/*",
    "http://localhost:11434/*"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://www.messenger.com/*"],
      "js": ["ollama.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "messenger-redactor@local"
    }
  }
}